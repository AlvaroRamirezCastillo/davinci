{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "/ui-metadata.schema.json",
  "title": "Davinci Server Driven UI Metadata",
  "type": "object",
  "required": ["schemaVersion", "layout", "dataContext", "components"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "1.1"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "layout": {
      "$ref": "#/$defs/gridLayout"
    },
    "dataContext": {
      "type": "object",
      "description": "View data available to component property bindings.",
      "additionalProperties": true
    },
    "components": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/component"
      }
    }
  },
  "$defs": {
    "gridLayout": {
      "type": "object",
      "required": ["type", "columns", "rows"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "grid"
        },
        "columns": {
          "type": "integer",
          "minimum": 1
        },
        "rows": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "component": {
      "type": "object",
      "required": ["id", "tag", "layout", "props"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1
        },
        "layout": {
          "$ref": "#/$defs/gridPlacement"
        },
        "props": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/componentProp"
          }
        },
        "events": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/eventBinding"
          }
        }
      }
    },
    "gridPlacement": {
      "type": "object",
      "required": ["column", "row", "columnSpan", "rowSpan"],
      "additionalProperties": false,
      "properties": {
        "column": {
          "type": "integer",
          "minimum": 1
        },
        "row": {
          "type": "integer",
          "minimum": 1
        },
        "columnSpan": {
          "type": "integer",
          "minimum": 1
        },
        "rowSpan": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "componentProp": {
      "oneOf": [
        {
          "$ref": "#/$defs/literalProp"
        },
        {
          "$ref": "#/$defs/boundProp"
        }
      ]
    },
    "literalProp": {
      "type": "object",
      "required": ["name", "value"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": {}
      }
    },
    "boundProp": {
      "type": "object",
      "required": ["name", "binding"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "binding": {
          "type": "string",
          "pattern": "^\\$dataContext\\.[A-Za-z0-9_-]+(?:\\.[A-Za-z0-9_-]+)*$",
          "description": "Runtime path such as $dataContext.countries.value."
        }
      }
    },
    "eventBinding": {
      "type": "object",
      "required": ["action"],
      "additionalProperties": true,
      "properties": {
        "action": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
